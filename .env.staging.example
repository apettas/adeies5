# Django
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key
ALLOWED_HOSTS=staging.example.gr
CSRF_TRUSTED_ORIGINS=https://staging.example.gr

# Database
DB_NAME=pdede_leaves_staging
DB_USER=pdede_user
DB_PASSWORD=replace-with-a-strong-database-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Email / protocol sending
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.sch.gr
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=your-sch-username@sch.gr
EMAIL_HOST_PASSWORD=replace-with-email-password
DEFAULT_FROM_EMAIL=your-sch-username@sch.gr
PROTOCOL_EMAIL_RECIPIENT=recipient@example.gr

# Reverse proxy / HTTPS
# Set these to True only after HTTPS is active for the staging domain.
NGINX_HTTP_PORT=80
USE_X_FORWARDED_PROTO=True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Enable HSTS only after HTTPS is confirmed working.
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_CONTENT_TYPE_NOSNIFF=True

# CAS SSO (ΠΣΔ / sch.gr)
# Test: https://sso-01-test.sch.gr  |  Production: https://sso.sch.gr
CAS_SERVER_URL=https://sso-01-test.sch.gr
CAS_ROOT_PROXIED_AS=https://sadeies.pdede.gov.gr
CAS_FORCE_SSL_SERVICE_URL=True

# Optional one-time admin bootstrap.
# Prefer creating the admin manually with:
# docker compose -f docker-compose.prod.yml exec web python manage.py createsuperuser
CREATE_DEFAULT_SUPERUSER=False
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=Staging

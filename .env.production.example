# Production — adeies.pdede.gov.gr
# Αντιγραφή: cp .env.production.example .env

DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key
ALLOWED_HOSTS=adeies.pdede.gov.gr,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://adeies.pdede.gov.gr

# Database
DB_NAME=pdede_leaves
DB_USER=pdede_user
DB_PASSWORD=replace-with-a-strong-database-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.sch.gr
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=your-sch-username@sch.gr
EMAIL_HOST_PASSWORD=replace-with-email-password
DEFAULT_FROM_EMAIL=your-sch-username@sch.gr
PROTOCOL_EMAIL_RECIPIENT=recipient@example.gr
ALERT_EMAIL=apettas@gmail.com
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1
NETDATA_PORT=19999
UPTIME_KUMA_PORT=3001

# Reverse proxy (Cloudflare Tunnel → localhost:80)
NGINX_HTTP_PORT=80
USE_X_FORWARDED_PROTO=True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_CONTENT_TYPE_NOSNIFF=True

# CAS SSO — production ΠΣΔ
CAS_SERVER_URL=https://sso.sch.gr
CAS_ROOT_PROXIED_AS=https://adeies.pdede.gov.gr
CAS_FORCE_SSL_SERVICE_URL=True
CAS_VERIFY_SSL_CERTIFICATE=True

CREATE_DEFAULT_SUPERUSER=False

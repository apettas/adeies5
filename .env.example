# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Settings
DB_NAME=pdede_leaves
DB_USER=pdede_user
DB_PASSWORD=pdede_password
DB_HOST=db
DB_PORT=5432

# Redis Settings
REDIS_URL=redis://redis:6379/0

# Email Settings (SMTP for sending protocol emails)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.sch.gr
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=your-sch-username@sch.gr
EMAIL_HOST_PASSWORD=your-sch-password
DEFAULT_FROM_EMAIL=your-sch-username@sch.gr

# Email recipient for protocol requests
PROTOCOL_EMAIL_RECIPIENT=apettas@gmail.com

# Security & monitoring alerts (Netdata, fail2ban, django-axes lockout)
ALERT_EMAIL=apettas@gmail.com
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1

# Monitoring services (localhost only — πρόσβαση μέσω SSH tunnel)
NETDATA_PORT=19999
UPTIME_KUMA_PORT=3001

# Web Server Settings
WEB_PORT=8000

# CAS SSO (ΠΣΔ / sch.gr) — αφήστε κενό για απενεργοποίηση (τοπική ανάπτυξη)
# Test: https://sso-01-test.sch.gr  |  Production: https://sso.sch.gr
# Production: adeies.pdede.gov.gr  |  Staging: sadeies.pdede.gov.gr
CAS_SERVER_URL=
CAS_ROOT_PROXIED_AS=
CAS_FORCE_SSL_SERVICE_URL=True

# Security Settings (Production)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False